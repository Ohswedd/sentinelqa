{
  "name": "@sentinelqa/ts-runtime",
  "version": "0.0.0",
  "private": true,
  "description": "SentinelQA TypeScript runtime — Playwright helpers, runtime tracing, JSONL bridge. PRD §15. Owns the TS side of the Python ↔ TS contract (ADR-0009).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./playwright": {
      "types": "./src/playwright.ts",
      "import": "./src/playwright.ts"
    },
    "./protocol": {
      "types": "./src/protocol.ts",
      "import": "./src/protocol.ts"
    },
    "./locators": {
      "types": "./src/locators.ts",
      "import": "./src/locators.ts"
    }
  },
  "bin": {
    "sentinel-ts": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/postbuild.mjs",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@playwright/test": "1.49.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.17.9",
    "@vitest/coverage-v8": "2.1.8",
    "ts-morph": "24.0.0",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
