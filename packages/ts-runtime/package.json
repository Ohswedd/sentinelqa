{
  "name": "@sentinelqa/ts-runtime",
  "version": "1.0.0",
  "description": "SentinelQA TypeScript runtime — Playwright helpers, runtime tracing, JSONL bridge. PRD §15. Owns the TS side of the Python ↔ TS contract (ADR-0009).",
  "license": "Apache-2.0",
  "author": "ohswedd",
  "homepage": "https://github.com/Ohswedd/sentinelqa#readme",
  "bugs": {
    "url": "https://github.com/Ohswedd/sentinelqa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ohswedd/sentinelqa.git",
    "directory": "packages/ts-runtime"
  },
  "keywords": [
    "sentinelqa",
    "playwright",
    "testing",
    "qa",
    "e2e",
    "automation",
    "release-confidence"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright.d.ts",
      "import": "./dist/playwright.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./locators": {
      "types": "./dist/locators.d.ts",
      "import": "./dist/locators.js"
    }
  },
  "bin": {
    "sentinel-ts": "./dist/cli.js"
  },
  "files": [
    "dist/**",
    "!dist/**/*.test.*",
    "!dist/**/*.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/postbuild.mjs",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:no-coverage": "vitest run",
    "test:smoke": "node fixtures/smoke-driver.mjs",
    "format": "prettier --write.",
    "format:check": "prettier --check."
  },
  "dependencies": {
    "@playwright/test": "1.49.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.17.9",
    "@vitest/coverage-v8": "2.1.8",
    "ts-morph": "24.0.0",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
