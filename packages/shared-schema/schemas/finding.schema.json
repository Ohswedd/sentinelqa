{
  "$defs": {
    "Evidence": {
      "additionalProperties": false,
      "description": "One artifact proving a finding.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "path": {
          "format": "path",
          "title": "Path",
          "type": "string"
        },
        "redacted": {
          "default": true,
          "title": "Redacted",
          "type": "boolean"
        },
        "type": {
          "enum": [
            "screenshot",
            "video",
            "trace",
            "har",
            "console_log",
            "network_log",
            "dom_snapshot",
            "stack_trace",
            "api_sample",
            "source_ref"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "id",
        "type",
        "path"
      ],
      "title": "Evidence",
      "type": "object"
    },
    "FindingLocation": {
      "additionalProperties": false,
      "description": "Where in the app a finding was observed.",
      "properties": {
        "file": {
          "anyOf": [
            {
              "maxLength": 2048,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File"
        },
        "line": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Line"
        },
        "route": {
          "anyOf": [
            {
              "maxLength": 2048,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Route"
        },
        "selector": {
          "anyOf": [
            {
              "maxLength": 2048,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Selector"
        }
      },
      "title": "FindingLocation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "A specific, evidence-backed defect observed during a run.\n\nWire format aligned with PRD \u00a718.2 (extended with the bookkeeping fields\nrequired by CLAUDE.md \u00a724: ``run_id``, ``module``, ``confidence``,\n``created_at``, ``schema_version``).",
  "properties": {
    "affected_target": {
      "anyOf": [
        {
          "maxLength": 2048,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Affected Target"
    },
    "attack_id": {
      "anyOf": [
        {
          "maxLength": 32,
          "pattern": "^T\\d{4}(\\.\\d{3})?$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Attack Id"
    },
    "category": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Category",
      "type": "string"
    },
    "compliance_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9.-]*:[A-Za-z0-9][A-Za-z0-9._/-]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Compliance Id"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "cwe_id": {
      "anyOf": [
        {
          "maxLength": 32,
          "pattern": "^CWE-\\d+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cwe Id"
    },
    "description": {
      "maxLength": 8000,
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/Evidence"
      },
      "title": "Evidence",
      "type": "array"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "location": {
      "$ref": "#/$defs/FindingLocation"
    },
    "module": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Module",
      "type": "string"
    },
    "owasp_api_id": {
      "anyOf": [
        {
          "maxLength": 32,
          "pattern": "^API-\\d{4}-\\d{2}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Owasp Api Id"
    },
    "recommendation": {
      "anyOf": [
        {
          "maxLength": 4000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Recommendation"
    },
    "reproduction_steps": {
      "items": {
        "type": "string"
      },
      "title": "Reproduction Steps",
      "type": "array"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "2",
      "title": "Schema Version",
      "type": "string"
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ],
      "title": "Severity",
      "type": "string"
    },
    "suggested_fix": {
      "anyOf": [
        {
          "maxLength": 4000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Suggested Fix"
    },
    "title": {
      "maxLength": 300,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "id",
    "run_id",
    "module",
    "category",
    "severity",
    "confidence",
    "title",
    "description",
    "created_at"
  ],
  "title": "Finding",
  "type": "object",
  "x-sentinelqa-schema-version": "2"
}
