{
  "name": "@sentinelqa/shared-schema",
  "version": "0.0.0",
  "private": true,
  "description": "JSON Schemas shared by the Python engine and the TypeScript runtime — wire formats for run, findings, score, and agent messages.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "20.17.9",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
