{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sentinelqa.dev/findings.schema.json",
  "title": "SentinelQA Findings Envelope",
  "description": "Top-level wire format for `.sentinel/runs/<run-id>/findings.json`. PRD §18.2, §20; CLAUDE.md §24.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "generated_at", "count", "findings"],
  "properties": {
    "schema_version": { "const": "2" },
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[A-Z0-9]{12}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/Finding" }
    }
  },
  "$defs": {
    "Finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "run_id",
        "module",
        "category",
        "severity",
        "confidence",
        "title",
        "description",
        "location",
        "evidence",
        "reproduction_steps",
        "suggested_fix",
        "recommendation",
        "affected_target",
        "cwe_id",
        "attack_id",
        "owasp_api_id",
        "compliance_id",
        "created_at",
        "schema_version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^FND-[A-Z0-9]{12}$"
        },
        "run_id": {
          "type": "string",
          "pattern": "^RUN-[A-Z0-9]{12}$"
        },
        "module": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "severity": {
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 8000
        },
        "location": { "$ref": "#/$defs/Location" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/Evidence" }
        },
        "reproduction_steps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "suggested_fix": {
          "type": ["string", "null"],
          "maxLength": 4000
        },
        "recommendation": {
          "type": ["string", "null"],
          "maxLength": 4000
        },
        "affected_target": {
          "type": ["string", "null"],
          "maxLength": 2048
        },
        "cwe_id": {
          "type": ["string", "null"],
          "pattern": "^CWE-[0-9]+$",
          "maxLength": 32
        },
        "attack_id": {
          "type": ["string", "null"],
          "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$",
          "maxLength": 32
        },
        "owasp_api_id": {
          "type": ["string", "null"],
          "pattern": "^API-[0-9]{4}-[0-9]{2}$",
          "maxLength": 32
        },
        "compliance_id": {
          "type": ["string", "null"],
          "pattern": "^[a-z][a-z0-9.-]*:[A-Za-z0-9][A-Za-z0-9._/-]*$",
          "maxLength": 128
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "schema_version": { "const": "2" }
      }
    },
    "Location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route", "selector", "file", "line"],
      "properties": {
        "route": { "type": ["string", "null"], "maxLength": 2048 },
        "selector": { "type": ["string", "null"], "maxLength": 2048 },
        "file": { "type": ["string", "null"], "maxLength": 2048 },
        "line": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path", "redacted"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^EVD-[A-Z0-9]{12}$"
        },
        "type": {
          "enum": [
            "screenshot",
            "video",
            "trace",
            "har",
            "console_log",
            "network_log",
            "dom_snapshot",
            "stack_trace",
            "api_sample",
            "source_ref"
          ]
        },
        "path": { "type": "string", "minLength": 1 },
        "redacted": { "type": "boolean" }
      }
    }
  }
}
