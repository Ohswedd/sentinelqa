{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sentinelqa.dev/run.schema.json",
  "title": "SentinelQA RunReport",
  "description": "Top-level wire format for `.sentinel/runs/<run-id>/run.json`. See the documentation, §20; the engineering guidelines, §38.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "started_at",
    "finished_at",
    "status",
    "target",
    "config_digest",
    "modules_run",
    "release_decision",
    "quality_score",
    "summary",
    "artifact_paths",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "description": "Major version of this schema. Bumped only on breaking changes.",
      "const": "1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[A-Z0-9]{12}$"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp in UTC."
    },
    "finished_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "status": {
      "enum": ["passed", "failed", "incomplete", "unsafe_blocked", "dry_run"]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_url", "host", "mode"],
      "properties": {
        "base_url": {
          "type": "string",
          "minLength": 1
        },
        "host": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "enum": ["safe", "authorized_destructive"]
        }
      }
    },
    "config_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 of the canonicalized config snapshot (sort_keys + minimal-whitespace JSON)."
    },
    "modules_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "uniqueItems": true
    },
    "release_decision": {
      "enum": ["pass", "pass_with_warnings", "blocked", "inconclusive", "unsafe_target_rejected"]
    },
    "quality_score": {
      "description": "0–100. Null for unsafe_blocked and dry_run runs (no score is meaningful).",
      "anyOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        {
          "type": "null"
        }
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "failed", "blocked", "info"],
      "properties": {
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "info": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["findings", "score", "junit", "sarif", "report_html", "report_md", "audit_log"],
      "properties": {
        "findings": {
          "type": ["string", "null"]
        },
        "score": {
          "type": ["string", "null"]
        },
        "junit": {
          "type": ["string", "null"]
        },
        "sarif": {
          "type": ["string", "null"]
        },
        "report_html": {
          "type": ["string", "null"]
        },
        "report_md": {
          "type": ["string", "null"]
        },
        "audit_log": {
          "type": ["string", "null"]
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          }
        }
      }
    }
  },
  "allOf": [
    {
      "description": "Unsafe-blocked and dry_run runs have no quality score.",
      "if": {
        "properties": {
          "status": {
            "enum": ["unsafe_blocked", "dry_run"]
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "quality_score": {
            "type": "null"
          }
        }
      }
    }
  ]
}
