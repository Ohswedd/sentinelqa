{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelqa.dev/schemas/agent-envelope.schema.json",
  "title": "SentinelQA MCP agent envelope",
  "description": "Wire shape returned by every sentinel.* MCP tool (ADR-0023).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tool"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "tool": {
      "type": "string",
      "pattern": "^sentinel\\.[a-z_]+$"
    },
    "result": {
      "anyOf": [
        {
          "type": "object"
        },
        {
          "type": "array"
        },
        {
          "type": "null"
        }
      ]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "code", "exit_code", "message"],
        "properties": {
          "type": {
            "type": "string",
            "const": "error"
          },
          "code": {
            "type": "string"
          },
          "exit_code": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7
          },
          "message": {
            "type": "string"
          },
          "suggested_fix": {
            "type": "string"
          },
          "context": {
            "type": "object"
          }
        },
        "additionalProperties": true
      },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "allOf": [
    {
      "description": "result XOR errors-non-empty: error envelopes carry no result.",
      "anyOf": [
        {
          "properties": {
            "result": {
              "not": {
                "type": "null"
              }
            }
          }
        },
        {
          "properties": {
            "errors": {
              "type": "array",
              "minItems": 1
            }
          },
          "required": ["errors"]
        }
      ]
    }
  ]
}
