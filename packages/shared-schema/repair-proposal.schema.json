{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sentinelqa.dev/repair-proposal.schema.json",
  "title": "RepairProposal",
  "description": "Healer-emitted repair proposal (PRD §9.6, CLAUDE.md §23, ADR-0025). Persisted under <run-dir>/healer/<id>.json.",
  "type": "object",
  "additionalProperties": false,
  "x-sentinelqa-schema-version": "1",
  "required": [
    "id",
    "kind",
    "target_test",
    "original_behavior",
    "proposed_change",
    "confidence",
    "reason",
    "evidence",
    "requires_human_review",
    "unified_diff",
    "schema_version"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "id": {
      "type": "string",
      "pattern": "^RPR-[A-Z0-9]{12}$"
    },
    "kind": {
      "type": "string",
      "enum": ["locator", "wait", "fixture", "assertion"]
    },
    "target_test": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "target_test_line": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 1000000
    },
    "original_behavior": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8000
    },
    "proposed_change": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8000
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Evidence"
      }
    },
    "requires_human_review": {
      "type": "boolean"
    },
    "unified_diff": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64000
    },
    "descriptor": {
      "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/LocatorDescriptor" }]
    }
  },
  "$defs": {
    "Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "screenshot",
            "video",
            "trace",
            "har",
            "console_log",
            "network_log",
            "dom_snapshot",
            "stack_trace",
            "api_sample",
            "source_ref",
            "note"
          ]
        },
        "path": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "redacted": { "type": "boolean", "default": true }
      }
    },
    "LocatorDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": { "type": ["string", "null"], "maxLength": 128 },
        "accessible_name": { "type": ["string", "null"], "maxLength": 512 },
        "text": { "type": ["string", "null"], "maxLength": 512 },
        "landmarks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tag_name": { "type": ["string", "null"], "maxLength": 64 }
      }
    }
  }
}
