{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sentinelqa.dev/plan.schema.json",
  "title": "SentinelQA Test Plan Envelope",
  "description": "Top-level wire format for `.sentinel/runs/<run-id>/plan.json`. PRD §9.2, §18; CLAUDE.md §11, §15.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan"],
  "properties": {
    "schema_version": { "const": "1" },
    "plan": { "$ref": "#/$defs/TestPlan" }
  },
  "$defs": {
    "TestPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "run_id",
        "discovery_graph_id",
        "risk_map_id",
        "target_url",
        "flows",
        "test_cases",
        "coverage_estimate",
        "schema_version"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^PLN-[A-Z0-9]{12}$" },
        "run_id": { "type": "string", "pattern": "^RUN-[A-Z0-9]{12}$" },
        "discovery_graph_id": { "type": "string", "pattern": "^DG-[A-Z0-9]{12}$" },
        "risk_map_id": { "type": "string", "pattern": "^RM-[A-Z0-9]{12}$" },
        "target_url": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "schema_version": { "const": "1" },
        "flows": {
          "type": "array",
          "items": { "$ref": "#/$defs/Flow" }
        },
        "test_cases": {
          "type": "array",
          "items": { "$ref": "#/$defs/TestCase" }
        },
        "coverage_estimate": { "$ref": "#/$defs/CoverageEstimate" }
      }
    },
    "Flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "steps",
        "priority",
        "risk",
        "confidence",
        "source",
        "schema_version"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^FLW-[A-Z0-9]{12}$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "description": { "type": "string", "maxLength": 2000 },
        "extractor": { "type": "string", "maxLength": 64 },
        "source": { "enum": ["deterministic", "llm"] },
        "priority": { "enum": ["P0", "P1", "P2", "P3"] },
        "risk": { "enum": ["critical", "high", "medium", "low"] },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "required_auth_role": { "type": ["string", "null"], "maxLength": 64 },
        "required_data_state": { "type": ["string", "null"], "maxLength": 200 },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/FlowStep" }
        },
        "schema_version": { "const": "1" }
      }
    },
    "FlowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "expected_outcome"],
      "properties": {
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "expected_outcome": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "target_route_id": {
          "type": ["string", "null"],
          "pattern": "^RT-[A-Z0-9]{12}$"
        },
        "target_element_id": {
          "type": ["string", "null"],
          "pattern": "^EL-[A-Z0-9]{12}$"
        }
      }
    },
    "TestCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "flow_id", "file_path", "test_type", "confidence", "schema_version"],
      "properties": {
        "id": { "type": "string", "pattern": "^TC-[A-Z0-9]{12}$" },
        "flow_id": { "type": "string", "pattern": "^FLW-[A-Z0-9]{12}$" },
        "file_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "test_type": {
          "enum": [
            "functional",
            "a11y",
            "api",
            "performance",
            "visual",
            "security",
            "chaos",
            "llm_audit",
            "regression"
          ]
        },
        "module": {
          "enum": [
            "functional",
            "a11y",
            "api",
            "performance",
            "visual",
            "security",
            "chaos",
            "llm_audit"
          ]
        },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "schema_version": { "const": "1" }
      }
    },
    "CoverageEstimate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by_module", "total", "schema_version"],
      "properties": {
        "by_module": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "total": { "type": "integer", "minimum": 0 },
        "schema_version": { "const": "1" }
      }
    }
  }
}
