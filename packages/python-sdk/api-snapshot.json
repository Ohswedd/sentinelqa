      },
      "PolicyPlugin": {
        "kind": "class",
        "model_fields": [],
        "own_attributes": [
          "evaluate",
          "kind"
        ]
      },
      "ReporterPlugin": {
        "kind": "class",
        "model_fields": [],
        "own_attributes": [
          "emit",
          "kind"
        ]
      },
      "RunnerPlugin": {
        "kind": "class",
        "model_fields": [],
        "own_attributes": [
          "kind",
          "run"
        ]
      },
      "ScannerPlugin": {
        "kind": "class",
        "model_fields": [],
        "own_attributes": [
          "kind",
          "run"
        ]
      }
    }
  },
  "schema_version": "1"
}
