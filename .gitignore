# SentinelQA .gitignore

# --- Internal-only artefacts (kept out of the public tree) ---------------
# These can exist locally for maintainer convenience but never land on main.
plans/
CLAUDE.md
PRD.md
docs/release/pre-1.0-review.md
docs/release/go-public-checklist.md
docs/release/announcement-draft.md
docs/release/*-audit-*.md
docs/release/dod-sweep-*.md
docs/release/prd-coverage.md
docs/release/claude-md-coverage.md
docs/release/bench-results-*.json

# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version
.mypy_cache/
.ruff_cache/
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.egg-info/
*.egg
.eggs/

# --- Node / TypeScript ---------------------------------------------------
node_modules/
.pnpm-store/
.turbo/
.next/
.svelte-kit/
.nuxt/
.cache/
.parcel-cache/
# Astro cache (Phase 27 — apps/docs Starlight site)
.astro/
# Vitest v8 coverage output (Phase 04.07). Coverage is enforced via
# the threshold block in `packages/ts-runtime/vitest.config.ts`; the
# emitted directory itself is a build artifact.
coverage/
**/coverage/

# --- Build output (Python + TS) ------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# --- Playwright ----------------------------------------------------------
playwright-report/
test-results/
traces/
**/playwright/.cache/

# --- SentinelQA runtime artifacts ----------------------------------------
.sentinel/runs/
.sentinel/baselines/
.sentinel/reports/
.sentinel/cache/
.sentinel/flake.db
.sentinel/flake.db-*

# --- Editors / OS noise --------------------------------------------------
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
*~

# Allow only a curated subset of .vscode/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# --- Secrets (CLAUDE.md §33) ---------------------------------------------
# Never commit .env files. .env.example is whitelisted below.
.env
.env.*
.env.local
!.env.example
!*.env.example

# Generic secret files
secrets.*
*.secret
secrets/

# Keys and credentials
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
id_rsa*
id_ed25519*
id_ecdsa*
known_hosts*

# Cloud credentials
.aws/
.gcloud/
gcp-key*.json
service-account*.json

# --- Misc ----------------------------------------------------------------
*.log
*.tmp
*.bak
.envrc
CHANGELOG.draft.md
