      "Content-Type": "application/json",
      "X-Api-Key": "live_key_12345"
    },
    "expected": {
      "Authorization": "[REDACTED:authorization]",
      "Cookie": "[REDACTED:cookie]",
      "Content-Type": "application/json",
      "X-Api-Key": "[REDACTED:x-api-key]"
    }
  },
  {
    "id": "headers-non-secret",
    "kind": "headers",
    "input": {
      "Accept": "text/html",
      "Host": "example.com",
      "User-Agent": "sentinel-test/1.0"
    },
    "expected": {
      "Accept": "text/html",
      "Host": "example.com",
      "User-Agent": "sentinel-test/1.0"
    }
  }
]
