    "expected": "the quick brown fox jumps over the lazy dog"
  },
  {
    "id": "gcp-service-account-marker",
    "kind": "string",
    "input": "config: { \"type\": \"service_account\", \"project_id\": \"foo\" }",
    "expected": "config: { [REDACTED:gcp_service_account], \"project_id\": \"foo\" }"
  },
  {
    "id": "value-dict-with-secrets",
    "kind": "value",
    "input": {
      "username": "alice",
      "password": "hunter2",
      "Authorization": "Bearer token-xyz-very-long-token-for-test-123",
      "extra": "ok"
    },
    "expected": {
      "username": "alice",
      "password": "[REDACTED:password]",
      "Authorization": "[REDACTED:authorization]",
      "extra": "ok"
    }
  },
  {
    "id": "value-nested-list",
    "kind": "value",
    "input": {
      "items": [
        {
          "api_key": "12345abcdef"
        },
        {
          "name": "no secret here"
        },
        {
          "Token": ""
        }
      ],
      "deep": {
        "level2": {
          "set_cookie": "sid=xyz"
        }
      }
    },
    "expected": {
      "items": [
        {
          "api_key": "[REDACTED:api_key]"
        },
        {
          "name": "no secret here"
        },
        {
          "Token": ""
        }
      ],
      "deep": {
        "level2": {
          "set_cookie": "[REDACTED:cookie]"
        }
      }
    }
  },
  {
    "id": "value-primitives",
    "kind": "value",
    "input": {
      "n": 42,
      "b": true,
      "x": null,
      "f": 1.5
    },
    "expected": {
      "n": 42,
      "b": true,
      "x": null,
      "f": 1.5
    }
  },
  {
    "id": "headers-mixed",
    "kind": "headers",
    "input": {
      "Authorization": "Bearer abc-def-ghi",
