# SentinelQA configuration example (PRD §17.1).
#
# Copy this file to `sentinel.config.yaml` at your project root and edit
# the values for your app. Secrets MUST come from environment variables —
# the loader rejects inline values for password / token / api_key keys.
# Authority: PRD §17, CLAUDE.md §6 (safety boundary), CLAUDE.md §12 (config rules).
version: 1

project:
  name: example-app
  framework: nextjs
  package_manager: pnpm

source:
  root: .
  include:
    - app
    - pages
    - src
  exclude:
    - node_modules
    - .next
    - dist

target:
  base_url: http://localhost:3000
  # Every host SentinelQA is allowed to touch. Wildcards are rejected
  # explicitly — list each authorized host (CLAUDE.md §6).
  allowed_hosts:
    - localhost
    - 127.0.0.1
    - staging.example.com
  # Only required when security.mode is `authorized_destructive`.
  # proof_of_authorization: ./.sentinel/auth/staging-proof.yaml

auth:
  strategy: test_user
  login_url: /login
  # Secrets come from env vars; never inline them here.
  username_env: TEST_USER_EMAIL
  password_env: TEST_USER_PASSWORD

modules:
  functional: true
  api: true
  accessibility: true
  performance: true
  visual: false
  security: true
  chaos: false
  llm_audit: true

security:
  # `safe` is the default; the only other value (`authorized_destructive`)
  # requires `target.proof_of_authorization` to point at a signed doc.
  mode: safe
  destructive_tests: false
  max_requests_per_second: 5
  allowed_payload_level: low

performance:
  # All performance measurements are SYNTHETIC (lab) — they catch
  # regressions reliably but are not Real-User Monitoring (CLAUDE §27).
  budgets:
    lcp_ms: 2500
    cls: 0.1
    inp_ms: 200
    ttfb_ms: 600
    api_p95_ms: 500
    js_total_kb: 500
    long_task_total_ms: 200
    dom_growth_pct: 10.0
    memory_growth_pct: 20.0
  # Routes the performance module audits. Empty (default) means the
  # module short-circuits unless the caller supplies routes via CLI
  # (--routes), `sentinel audit` discovery, or this block.
  routes: []
  # Samples per route for LCP/CLS/INP/TTFB; the module reports the
  # median. Default 3 keeps runs short while smoothing noise.
  samples: 3
  # Visits per route for the memory-leak heuristic (DOM-node count +
  # JS heap growth). Default 5; lowest legal value is 2.
  repeated_nav_samples: 5
  # Skip the P95 check for endpoints with fewer than N samples.
  api_min_samples_for_p95: 5
  # Per-route Playwright budget; multiplied by (samples + nav samples)
  # for the overall subprocess timeout.
  request_timeout_seconds: 30
  # Optional path-prefix allowlist for API timing collection. Empty
  # means: classify by content-type / /api/ or /graphql heuristic.
  api_path_allowlist: []

visual:
  baselines_dir: .sentinel/baselines
  threshold: 0.02
  mask_dynamic_content: true

planner:
  # Deterministic core ships in Phase 06. The LLM adapter is opt-in
  # behind the `enabled` flag (ADR-0011). Provider keys are read from the
  # env var named in `api_key_env`; they are never inlined here
  # (CLAUDE.md §33).
  llm:
    enabled: false
    # provider: "null" | "openai" | "anthropic"
    provider: "null"
    # model: ""   # leave empty to use the provider's default
    # api_key_env: OPENAI_API_KEY
    max_proposals: 10
    max_usd_per_run: 0.50
    request_timeout_seconds: 30.0

analyzer:
  # Deterministic core ships in Phase 09. The LLM explainer adds at most
  # one sentence of refinement to the deterministic hypothesis — it never
  # replaces the category, hypothesis, or confidence (CLAUDE §23).
  llm:
    enabled: false
    # provider: "null" | "openai" | "anthropic"
    provider: "null"
    # model: ""   # leave empty to use the provider's default
    # api_key_env: ANTHROPIC_API_KEY
    max_usd_per_run: 0.25
    request_timeout_seconds: 20.0

accessibility:
  # `sentinel a11y` controls (Phase 11, ADR-0016).
  # `axe.tags` defaults to WCAG 2.0 A + AA plus axe's curated
  # best-practice set. CLAUDE §28: outputs always say "Automated
  # accessibility check found" — they never claim "fully WCAG compliant".
  axe:
    tags:
      - wcag2a
      - wcag2aa
      - best-practice
  # routes:
  #   - /
  #   - /dashboard
  keyboard_max_tabs: 200
  request_timeout_seconds: 30.0

policy:
  min_quality_score: 85
  block_on_critical: true
  block_on_high_security: true
  max_flake_rate: 0.03
  allow_medium_a11y: false
  max_failed_p1_flows: 0

runner:
  # `sentinel test` controls (Phase 08, ADR-0013). The runner is
  # Playwright-native; choose between local execution and the pinned
  # Docker image (`mcr.microsoft.com/playwright:v1.49.0-jammy`).
  workers: auto              # auto | <int 1-64>
  # shards: "1/4"            # uncomment to split across CI nodes
  browser: chromium          # chromium | firefox | webkit
  headless: true
  timeout_ms: 30000
  docker: false
  docker_image: "mcr.microsoft.com/playwright:v1.49.0-jammy"
  retries:
    # Pass-on-retry is recorded as `flaky` and counts toward `policy.max_flake_rate`.
    max: 1
    backoff_ms: 1000
  quarantine:
    # Strict YAML list (test_id, reason, expires_at, issue_url).
    # See ADR-0013 / CLAUDE.md §23 — entries past `expires_at` OR
    # further out than `max_age_days` are rejected at load time, by design.
    path: tests/sentinel/.quarantine.yaml
    max_age_days: 14

report:
  output_dir: .sentinel/reports
  formats:
    - html
    - json
    - junit
    - sarif
