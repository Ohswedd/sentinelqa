{
  "manifest_version": 3,
  "name": "SentinelQA",
  "version": "1.1.0",
  "description": "Audit the current tab with a local SentinelQA MCP server (loopback only).",
  "homepage_url": "https://github.com/Ohswedd/sentinelqa",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "SentinelQA — Audit this page",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ]
}
