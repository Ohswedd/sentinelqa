{{ banner }}
import { sentinelTest as test, expect } from '@sentinelqa/ts-runtime/playwright';

test.describe({{ resource_title | js_string }} + ' — update', () => {
  test(
    'user can update an existing ' + {{ resource_singular | js_string }},
    { tag: [{% for tag in tags %}{{ tag | js_string }}{% if not loop.last %}, {% endif %}{% endfor %}] },
    async ({ page }) => {
      await page.goto({{ edit_path | js_string }});

      await test.step('change a field', async () => {
        const field = page.getByLabel({{ field_label | regex_pattern }});
        await field.fill('');
        await field.fill({{ updated_value | js_string }});
      });

      await test.step('save', async () => {
        await page.getByRole('button', { name: {{ save_label | regex_pattern }} }).click();
      });

      await test.step('confirm update outcome', async () => {
        await expect(page).toHaveURL({{ success_url_regex | regex_pattern }});
{% if success_text %}
        await expect(page.getByText({{ success_text | regex_pattern }})).toBeVisible();
{% endif %}
      });
    },
  );
});
