# SentinelQA — environment variable template.
#
# Copy this file to `.env` (which is git-ignored) and fill in real values
# locally. Never commit `.env`. See docs/dev/secret-hygiene.md and
# CLAUDE.md §33.

# --- Test users -----------------------------------------------------------
# Default credentials used by example apps and login flow tests.
# These are placeholders; real credentials live only in your local .env or
# in your CI secret store.
TEST_USER_EMAIL=test+user@example.com
TEST_USER_PASSWORD=replace-me-locally

# --- SentinelQA runtime ---------------------------------------------------
# debug | info | warn | error
SENTINEL_LOG_LEVEL=info

# true when running inside CI; disables interactive prompts and enforces
# configured quality gates (CLAUDE.md §39).
SENTINEL_CI=false

# --- LLM adapters (optional; only when the planner/analyzer LLM is enabled) ---
# Leave blank to disable the LLM adapter. SentinelQA must never call an LLM
# unless explicitly configured. See PRD §6.8 (deterministic-first).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Remote browser providers (Phase 25 — `integrations/`) ---------------
# Used only when remote execution is explicitly enabled in
# sentinel.config.yaml. Leave blank to keep execution local.
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=

# --- Notifications (Phase 25 — `integrations/slack`) ---------------------
# A Slack incoming-webhook URL for release-confidence summaries.
SLACK_WEBHOOK_URL=
